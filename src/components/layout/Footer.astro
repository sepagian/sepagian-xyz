---
import { themeConfig } from "@/config";

const today = new Date();
---

<footer>
  <div class="footer-content">
    <div class="copyright"><span>To define is to limit</span></div>
    <div class="powered-by">
      <span class="date">
        &copy;
        {today.getFullYear()}
      </span>
      {themeConfig.site.author}
    </div>
  </div>
</footer>
<style>
  footer {
  margin-top: 4rem;
  font-size: var(--font-size-s);
  font-weight: var(--font-weight-light);
  line-height: 1.75;
  color: var(--text-primary);
  opacity: 0.75;
}

.footer-content {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.copyright,
.powered-by {
  white-space: nowrap;
}

.copyright .date {
  opacity: 1;
}

footer a {
  color: var(--text-primary);
  text-decoration: none;
  transition: color 0.2s ease-out;
}

footer a:hover {
  color: var(--text-primary);
}
</style>
