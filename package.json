{
  "name": "sepagian-xyz",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "dev:studio": "cd studio && bun run sanity dev",
    "build": "wrangler types && vp build",
    "build:studio": "cd studio && bun run sanity build",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "prepare": "vp config && svelte-kit sync || echo ''",
    "deploy": "bunx wrangler types && bunx wrangler deploy",
    "deploy:studio": "cd studio && bun run sanity deploy",
    "check": "bunx svelte-check",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "ultracite": "ultracite check",
    "gen": "wrangler types",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@lucide/svelte": "^1.3.0",
    "@portabletext/svelte": "^3.0.1",
    "@portabletext/types": "^4.0.2",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "@unocss/extractor-svelte": "^66.7.0",
    "highlight.js": "^11.11.1",
    "mode-watcher": "^1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@poppanator/sveltekit-svg": "^7.0.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.9.1",
    "@unocss/svelte-scoped": "^66.6.8",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "ultracite": "7.7.0",
    "unocss": "^66.6.8",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "^4.94.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.14"
}
